# Minimal EVA configuration for the Labstr interview agent.
# Run from /Users/adrien/workspace/labstr/vendor/eva

EVA_DOMAIN=labstr
EVA_FRAMEWORK=pipecat
EVA_RECORD_IDS=labstr-jamie-1,labstr-jamie-2
EVA_MAX_CONCURRENT_CONVERSATIONS=1
EVA_CONVERSATION_TIMEOUT_SECONDS=420

# Text-only iteration helper: intentionally stop after N completed turns,
# but still compute metrics on the partial conversation.
# Used by scripts/run_text_only.py only.
# STOP_AT_TURN=4

# Recommended while adapting the survey agent: focus on EVA-X plus text judges.
# task_completion will trivially pass because the Labstr survey flow has no backend tools yet.
EVA_METRICS=faithfulness,conciseness,conversation_progression,turn_taking,conversation_valid_end,user_behavioral_fidelity

# User simulator
ELEVENLABS_API_KEY=your_elevenlabs_api_key
EVA_DEFAULT_USER_F=your_elevenlabs_female_agent_id
EVA_DEFAULT_USER_M=your_elevenlabs_male_agent_id

# Judge model routing
# Pick one provider block below.

# Option A: Groq + Llama
GROQ_API_KEY=your_groq_api_key
JUDGE_MODEL=judge-llama
EVA_MODEL_LIST='[{"model_name":"judge-llama","litellm_params":{"model":"groq/llama-3.3-70b-versatile","api_key":"os.environ/GROQ_API_KEY"}}]'

# Text judge overrides.
# These are especially useful with Groq because EVA's upstream text-judge
# default max_tokens is too high for Groq chat completions.
EVA_JUDGE_MAX_TOKENS=4096
# EVA_JUDGE_TEMPERATURE=0
# EVA_JUDGE_TOP_P=1
# EVA_JUDGE_REASONING_EFFORT=low

# Option B: xAI Grok
# XAI_API_KEY=your_xai_api_key
# JUDGE_MODEL=judge-grok
# EVA_MODEL_LIST='[{"model_name":"judge-grok","litellm_params":{"model":"xai/grok-2-latest","api_key":"os.environ/XAI_API_KEY"}}]'

# Voice option A: Pipecat + Gemini Live
EVA_MODEL__S2S=gemini-live
EVA_MODEL__S2S_PARAMS='{"api_key":"your_google_api_key","model":"models/gemini-live-2.5-flash-preview","voice":"Charon","vad_disabled":true}'

# Voice option B: Pipecat + AWS Bedrock Nova Sonic
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
# AWS_REGION=us-east-1
# EVA_MODEL__S2S=aws-nova-sonic
# EVA_MODEL__S2S_PARAMS='{"access_key_id":"os.environ/AWS_ACCESS_KEY_ID","secret_access_key":"os.environ/AWS_SECRET_ACCESS_KEY","session_token":"os.environ/AWS_SESSION_TOKEN","region":"os.environ/AWS_REGION","model":"amazon.nova-2-sonic-v1:0","voice":"matthew"}'

# Only needed if you later enable audio fidelity metrics
# EVA_AUDIO_JUDGE_MAX_TOKENS=8192
# EVA_AUDIO_JUDGE_TEMPERATURE=0
# EVA_AUDIO_JUDGE_TOP_P=1
# EVA_AUDIO_JUDGE_REASONING_EFFORT=minimal
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
